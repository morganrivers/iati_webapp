1071"/><mxPoint x="558" y="1071"/><mxPoint x="558" y="1071"/><mxPoint x="558" y="349"/><mxPoint x="558" y="349"/><mxPoint x="488" y="256"/></Array></mxGeometry></mxCell><mxCell id="e46" value="shap_result" style="edgeStyle=none;curved=1;html=1;endArrow=block;endFill=1;strokeColor=#9aa6b3;fontSize=9;fontColor=#5b6675;strokeColor=#2e8b57;" edge="1" parent="1" source="shapout" target="pforecast"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="261" y="1160"/><mxPoint x="295" y="1071"/><mxPoint x="295" y="1071"/><mxPoint x="295" y="1071"/><mxPoint x="295" y="1071"/><mxPoint x="295" y="349"/><mxPoint x="295" y="349"/><mxPoint x="354" y="257"/></Array></mxGeometry></mxCell><mxCell id="e47" value="tag_predictions" style="edgeStyle=none;curved=1;html=1;endArrow=block;endFill=1;strokeColor=#9aa6b3;fontSize=9;fontColor=#5b6675;strokeColor=#2e8b57;" edge="1" parent="1" source="tagout" target="pforecast"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="477" y="1160"/><mxPoint x="451" y="1071"/><mxPoint x="451" y="1071"/><mxPoint x="451" y="1071"/><mxPoint x="451" y="1071"/><mxPoint x="451" y="349"/><mxPoint x="451" y="349"/><mxPoint x="434" y="258"/></Array></mxGeometry></mxCell><mxCell id="e48" style="edgeStyle=none;curved=1;html=1;endArrow=block;endFill=1;strokeColor=#9aa6b3;fontSize=9;fontColor=#5b6675;strokeColor=#2e8b57;" edge="1" parent="1" source="cache" target="pextracted"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="1509" y="1774"/><mxPoint x="1551" y="1741"/><mxPoint x="1551" y="1741"/><mxPoint x="1551" y="1741"/><mxPoint x="1675" y="1591"/><mxPoint x="1675" y="1591"/><mxPoint x="1675" y="1591"/><mxPoint x="1675" y="1591"/><mxPoint x="1675" y="349"/><mxPoint x="1675" y="349"/><mxPoint x="1531" y="253"/></Array></mxGeometry></mxCell><mxCell id="e49" style="edgeStyle=none;curved=1;html=1;endArrow=block;endFill=1;strokeColor=#9aa6b3;fontSize=9;fontColor=#5b6675;strokeColor=#2e8b57;" edge="1" parent="1" source="narr" target="prag"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="811" y="283"/><mxPoint x="811" y="237"/></Array></mxGeometry></mxCell><mxCell id="e50" value="metrics" style="edgeStyle=none;curved=1;html=1;endArrow=block;endFill=1;strokeColor=#9aa6b3;fontSize=9;fontColor=#5b6675;strokeColor=#8493a4;dashed=1;" edge="1" parent="1" source="SX_train_pperf" target="pperf"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="1060" y="124"/><mxPoint x="1073" y="98"/></Array></mxGeometry></mxCell><mxCell id="e51" style="edgeStyle=none;curved=1;html=1;endArrow=block;endFill=1;strokeColor=#9aa6b3;fontSize=9;fontColor=#5b6675;strokeColor=#8493a4;dashed=1;" edge="1" parent="1" source="app" target="pmisc"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="1073" y="2982"/><mxPoint x="1741" y="2826"/><mxPoint x="1741" y="2826"/><mxPoint x="1741" y="2826"/><mxPoint x="1741" y="2826"/><mxPoint x="1741" y="349"/><mxPoint x="1741" y="349"/><mxPoint x="1720" y="258"/></Array></mxGeometry></mxCell><object label="PDF upload&lt;br&gt;/ manual entry&lt;br&gt;webapp/pages/activity_forecasting/upload.py" tooltip="&lt;b&gt;webapp/pages/activity_forecasting/upload.py&lt;/b&gt;&lt;br&gt;&lt;br&gt;User uploads a project-document PDF (or types activity details) on the Activity Forecasting page. Rendered by the upload submodule of the pages/activity_forecasting/ package." link="https://github.com/morganrivers/iati_webapp/blob/main/webapp/pages/activity_forecasting/upload.py" id="upload"><mxCell style="rounded=1;whiteSpace=wrap;html=1;arcSize=45;fillColor=#2f7dc4;strokeColor=#1c4f80;fontColor=#ffffff;fontSize=11;" vertex="1" parent="1"><mxGeometry x="642" y="2887" width="307" height="65" as="geometry"/></mxCell></object><object label="app.py&lt;br&gt;(Streamlit host)&lt;br&gt;webapp/app.py" tooltip="&lt;b&gt;webapp/app.py&lt;/b&gt;&lt;br&gt;&lt;br&gt;Streamlit entrypoint. Renders the sidebar nav over 7 pages and loads the model + training data once at startup via model_loader." link="https://github.com/morganrivers/iati_webapp/blob/main/webapp/app.py" id="app"><mxCell style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;fillColor=#dfe7ef;strokeColor=#6b7f96;fontColor=#1b2733;" vertex="1" parent="1"><mxGeometry x="731" y="3016" width="129" height="65" as="geometry"/></mxCell></object><object label="model_loader&lt;br&gt;webapp/model_loader.py" tooltip="&lt;b&gt;webapp/model_loader.py&lt;/b&gt;&lt;br&gt;&lt;br&gt;Loads the trained Random Forest + ExtraTrees ensemble, per-org baseline, start-year correction, feature medians, metadata, and training data from data/rating_model_outputs at startup." link="https://github.com/morganrivers/iati_webapp/blob/main/webapp/model_loader.py" id="loader"><mxCell style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;fillColor=#dfe7ef;strokeColor=#6b7f96;fontColor=#1b2733;" vertex="1" parent="1"><mxGeometry x="308" y="2894" width="169" height="50" as="geometry"/></mxCell></object><object label="model.pkl&lt;br&gt;extra_model.pkl&lt;br&gt;data/rating_model_outputs/" tooltip="&lt;b&gt;data/rating_model_outputs/&lt;/b&gt;&lt;br&gt;&lt;br&gt;Trained Random Forest + ExtraTrees delta regressors (model.pkl, extra_model.pkl), plus per-org baseline (per_org_baseline.json), start-year correction (start_year_correction.json), feature medians (train_medians.json), and feature names (feature_names.json) produced offline by the forecasting model-training pipeline." link="https://github.com/morganrivers/iati_webapp/tree/main/data/rating_model_outputs" id="rfpkl"><mxCell style="rounded=1;whiteSpace=wrap;html=1;arcSize=45;fillColor=#2f7dc4;strokeColor=#1c4f80;fontColor=#ffffff;fontSize=11;" vertex="1" parent="1"><mxGeometry x="286" y="3016" width="195" height="65" as="geometry"/></mxCell></object><object label="train_features.csv&lt;br&gt;(~1,300 activities)&lt;br&gt;data/rating_model_outputs/train_features.csv" tooltip="&lt;b&gt;data/rating_model_outputs/train_features.csv&lt;/b&gt;&lt;br&gt;&lt;br&gt;Historical IATI activity features + ratings. Used as the model&#x27;s reference distribution, for performance metrics, and as the RAG retrieval corpus. Consumed in several bands, so it is exported via the ✳ proxy convention (a small &#x27;train_features.csv ✳&#x27; chip beside each importer) rather than long lines." link="https://github.com/morganrivers/iati_webapp/blob/main/data/rating_model_outputs/train_features.csv" id="train"><mxCell style="shape=cylinder;whiteSpace=wrap;html=1;fillColor=#e6ecf3;strokeColor=#8493a4;fontColor=#1b2733;fontSize=11;" vertex="1" parent="1"><mxGeometry x="1668" y="3013" width="314" height="71" as="geometry"/></mxCell></object><object label="✳" tooltip="train_features.csv is exported via the ✳ proxy convention: each importer is drawn with a small &#x27;train_features.csv ✳&#x27; chip beside it rather than long lines from this file." link="https://github.com/morganrivers/iati_webapp/blob/main/data/rating_model_outputs/train_features.csv" id="STAR_train"><mxCell style="shape=note;whiteSpace=wrap;html=1;size=14;fillColor=#fdf3cf;strokeColor=#c9a227;fontColor=#5b4a00;fontSize=12;dashed=1;" vertex="1" parent="1"><mxGeometry x="1805" y="2903" width="70" height="32" as="geometry"/></mxCell></object><object label="trained_umap_models_&lt;br&gt;trainval.pkl&lt;br&gt;data/trained_umap_models_trainval.pkl" tooltip="&lt;b&gt;data/trained_umap_models_trainval.pkl&lt;/b&gt;&lt;br&gt;&lt;br&gt;Saved UMAP reducers that compress target/summary embeddings into a small set of embedding features." link="https://github.com/morganrivers/iati_webapp/blob/main/data/trained_umap_models_trainval.pkl" id="umap"><mxCell style="rounded=1;whiteSpace=wrap;html=1;arcSize=45;fillColor=#2f7dc4;strokeColor=#1c4f80;fontColor=#ffffff;fontSize=11;" vertex="1" parent="1"><mxGeometry x="1001" y="1676" width="268" height="65" as="geometry"/></mxCell></object><object label="tag_models.pkl&lt;br&gt;data/outcome_tags/tag_models.pkl" tooltip="&lt;b&gt;data/outcome_tags/tag_models.pkl&lt;/b&gt;&lt;br&gt;&lt;br&gt;Per-outcome-tag classifiers produced offline by the forecasting model-training pipeline. Loaded at runtime by tag_model_loader.py and consumed by tag_predictor to score individual success dimensions." link="https://github.com/morganrivers/iati_webapp/blob/main/data/outcome_tags/tag_models.pkl" id="tagpkl"><mxCell style="rounded=1;whiteSpace=wrap;html=1;arcSize=45;fillColor=#2f7dc4;strokeColor=#1c4f80;fontColor=#ffffff;fontSize=11;" vertex="1" parent="1"><mxGeometry x="904" y="1454" width="235" height="50" as="geometry"/></mxCell></object><object label="build_webapp_db&lt;br&gt;(offline prep)&lt;br&gt;webapp/scripts/build_webapp_db.py" tooltip="&lt;b&gt;webapp/scripts/build_webapp_db.py&lt;/b&gt;&lt;br&gt;&lt;br&gt;Offline one-off. Packs the training-data CSV plus summaries/risks/retrospective-forecast JSONL into data/webapp.db (tables activity_info and mock_forecasts)." link="https://github.com/morganrivers/iati_webapp/blob/main/webapp/scripts/build_webapp_db.py" id="builddb"><mxCell style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;fillColor=#dfe7ef;strokeColor=#6b7f96;fontColor=#1b2733;" vertex="1" parent="1"><mxGeometry x="1253" y="926" width="241" height="65" as="geometry"/></mxCell></object><object label="build_embeddings_db&lt;br&gt;(offline prep)&lt;br&gt;webapp/build_embeddings_db.py" tooltip="&lt;b&gt;webapp/build_embeddings_db.py&lt;/b&gt;&lt;br&gt;&lt;br&gt;Offline one-off. Adds an embeddings table to data/webapp.db from activity_text_embeddings_gemini.jsonl, stored as float32 BLOBs so the DB is small enough to commit." link="https://github.com/morganrivers/iati_webapp/blob/main/webapp/build_embeddings_db.py" id="buildemb"><mxCell style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;fillColor=#dfe7ef;strokeColor=#6b7f96;fontColor=#1b2733;" vertex="1" parent="1"><mxGeometry x="941" y="926" width="215" height="65" as="geometry"/></mxCell></object><object label="webapp.db&lt;br&gt;(SQLite)&lt;br&gt;data/webapp.db" tooltip="&lt;b&gt;data/webapp.db&lt;/b&gt;&lt;br&gt;&lt;br&gt;SQLite corpus database: activity_info, mock_forecasts, and embeddings tables. Built offline by the build_* scripts; read at runtime by sqlite_loaders." link="https://github.com/morganrivers/iati_webapp/blob/main/data/webapp.db" id="webappdb"><mxCell style="shape=cylinder;whiteSpace=wrap;html=1;fillColor=#e6ecf3;strokeColor=#8493a4;fontColor=#1b2733;fontSize=11;" vertex="1" parent="1"><mxGeometry x="991" y="794" width="116" height="71" as="geometry"/></mxCell></object><object label="sqlite_loaders&lt;br&gt;webapp/modules/sqlite_loaders.py" tooltip="&lt;b&gt;webapp/modules/sqlite_loaders.py&lt;/b&gt;&lt;br&gt;&lt;br&gt;Runtime reader of webapp.db. Supplies the BM25 retrieval corpus, activity-info lookups, and lazy mock forecasts that ground the narrative forecast." link="https://github.com/morganrivers/iati_webapp/blob/main/webapp/modules/sqlite_loaders.py" id="sqlite"><mxCell style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;fillColor=#f6d9c0;strokeColor=#c17a3a;fontColor=#5a3410;" vertex="1" parent="1"><mxGeometry x="921" y="683" width="235" height="50" as="geometry"/></mxCell></object><object label="train_features.csv ✳" tooltip="Proxy for train_features.csv (see the ✳ node); loaded here by model_loader at startup." link="https://github.com/morganrivers/iati_webapp/blob/main/data/rating_model_outputs/train_features.csv" id="SX_train_loader"><mxCell style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eef2f7;strokeColor=#8493a4;fontColor=#5b6675;fontSize=9;dashed=1;" vertex="1" parent="1"><mxGeometry x="514" y="3031" width="156" height="35" as="geometry"/></mxCell></object><object label="train_features.csv ✳" tooltip="Proxy for train_features.csv (see the ✳ node); the historical-activity rows that build_webapp_db packs into webapp.db to become the RAG retrieval corpus." link="https://github.com/morganrivers/iati_webapp/blob/main/data/rating_model_outputs/train_features.csv" id="SX_train_rag"><mxCell style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eef2f7;strokeColor=#8493a4;fontColor=#5b6675;fontSize=9;dashed=1;" vertex="1" parent="1"><mxGeometry x="1296" y="1052" width="156" height="35" as="geometry"/></mxCell></object><object label="train_features.csv ✳" tooltip="Proxy for train_features.csv (see the ✳ node); source of the validation metrics shown on the Model Performance page." link="https://github.com/morganrivers/iati_webapp/blob/main/data/rating_model_outputs/train_features.csv" id="SX_train_pperf"><mxCell style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eef2f7;strokeColor=#8493a4;fontColor=#5b6675;fontSize=9;dashed=1;" vertex="1" parent="1"><mxGeometry x="965" y="141" width="156" height="35" as="geometry"/></mxCell></object><object label="webapp_pipeline&lt;br&gt;(orchestrator)&lt;br&gt;webapp/modules/webapp_pipeline.py" tooltip="&lt;b&gt;webapp/modules/webapp_pipeline.py&lt;/b&gt;&lt;br&gt;&lt;br&gt;process_uploaded_pdf(): runs the 5-phase extraction on one PDF. Caches every output under projects/{activity_id}/ and reuses it on re-upload (activity_id = PDF content hash)." link="https://github.com/morganrivers/iati_webapp/blob/main/webapp/modules/webapp_pipeline.py" id="pipeline"><mxCell style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;fillColor=#cfe6cf;strokeColor=#5a9367;fontColor=#1e3a24;" vertex="1" parent="1"><mxGeometry x="642" y="2698" width="241" height="65" as="geometry"/></mxCell></object><object label="🤖 metadata_extractor&lt;br&gt;webapp/modules/metadata_extractor.py" tooltip="&lt;b&gt;webapp/modules/metadata_extractor.py&lt;/b&gt;&lt;br&gt;&lt;br&gt;Phase 1/5: LLM extracts title, reporting/participating orgs, country locations, and dates." link="https://github.com/morganrivers/iati_webapp/blob/main/webapp/modules/metadata_extractor.py" id="meta"><mxCell style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;fillColor=#cfe6cf;strokeColor=#5a9367;fontColor=#1e3a24;" vertex="1" parent="1"><mxGeometry x="667" y="2587" width="281" height="50" as="geometry"/></mxCell></object><object label="🤖 page_categorizer&lt;br&gt;webapp/modules/page_categorizer.py" tooltip="&lt;b&gt;webapp/modules/page_categorizer.py&lt;/b&gt;&lt;br&gt;&lt;br&gt;Phase 2/5: LLM labels each PDF page as table_of_contents, blank_page, glossary, references, core_activities, theory_of_change, targets, broader_context, preliminary_results, other, condensed_summary, sub_activities_outlined, detailed_implementation_plans, broad_objectives, possible_outcomes, quantitative_targets, qualitative_targets, risks_as_word_or_numeric, risks_or_dangers_generally, plans_to_address_key_risks, positive_indicators, progress_reports, similar_cases_outcomes, implementation_context_country, contextual_challenges, financing_details, budget_and_legal, who_implements, whether_part_of_larger_program, partner_identity_or_skill, whether_skin_in_the_game, other_stakeholder_engagement, activity_monitoring_details" link="https://github.com/morganrivers/iati_webapp/blob/main/webapp/modules/page_categorizer.py" id="pagecat"><mxCell style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;fillColor=#cfe6cf;strokeColor=#5a9367;fontColor=#1e3a24;" vertex="1" parent="1"><mxGeometry x="1115" y="2476" width="268" height="50" as="geometry"/></mxCell></object><object label="🤖 summary_generator&lt;br&gt;webapp/modules/summary_generator.py" tooltip="&lt;b&gt;webapp/modules/summary_generator.py&lt;/b&gt;&lt;br&gt;&lt;br&gt;Phase 3/5: LLM writes an activity-description summary from the categorized pages." link="https://github.com/morganrivers/iati_webapp/blob/main/webapp/modules/summary_generator.py" id="summary"><mxCell style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;fillColor=#cfe6cf;strokeColor=#5a9367;fontColor=#1e3a24;" vertex="1" parent="1"><mxGeometry x="1236" y="2365" width="275" height="50" as="geometry"/></mxCell></object><object label="🤖 finance_extractor&lt;br&gt;(+ sector_extractor)&lt;br&gt;webapp/modules/finance_extractor.py" tooltip="&lt;b&gt;webapp/modules/finance_extractor.py&lt;/b&gt;&lt;br&gt;&lt;br&gt;Phase 4/5: LLM extracts a finance breakdown (allocations, total amount); a companion sector_extractor.py allocates expenditure across the model&#x27;s sector clusters in the same phase." link="https://github.com/morganrivers/iati_webapp/blob/main/webapp/modules/finance_extractor.py" id="finance"><mxCell style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;fillColor=#cfe6cf;strokeColor=#5a9367;fontColor=#1e3a24;" vertex="1" parent="1"><mxGeometry x="1050" y="2239" width="275" height="65" as="geometry"/></mxCell></object><object label="🤖 feature_extractor&lt;br&gt;webapp/modules/feature_extractor.py" tooltip="&lt;b&gt;webapp/modules/feature_extractor.py&lt;/b&gt;&lt;br&gt;&lt;br&gt;Phase 5/5: LLM extracts baseline features: implementer performance, targets, risks, context, finance-qualitative, and complexity/integratedness." link="https://github.com/morganrivers/iati_webapp/blob/main/webapp/modules/feature_extractor.py" id="features"><mxCell style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;fillColor=#cfe6cf;strokeColor=#5a9367;fontColor=#1e3a24;" vertex="1" parent="1"><mxGeometry x="984" y="2128" width="275" height="50" as="geometry"/></mxCell></object><object label="projects/{activity_id}/&lt;br&gt;(uploaded.pdf + phase .jsonl)&lt;br&gt;projects/{activity_id}/" tooltip="&lt;b&gt;projects/{activity_id}/&lt;/b&gt;&lt;br&gt;&lt;br&gt;Per-PDF extraction artifacts: uploaded.pdf plus metadata.json and implementer_performance.jsonl / targets.jsonl / risks.jsonl / context.jsonl / finance_qualitative.jsonl / misc.jsonl / page_categories.jsonl / summary.jsonl / finance_breakdown.jsonl. Written by the extraction phases; the PREDICT band later writes feature_grades.jsonl and targets_embedding_features.jsonl back here. Reused on re-upload of the same PDF." link="https://github.com/morganrivers/iati_webapp/tree/main/projects/webapp_39a1625529b1" id="cache"><mxCell style="shape=cylinder;whiteSpace=wrap;html=1;fillColor=#e6ecf3;strokeColor=#8493a4;fontColor=#1b2733;fontSize=11;" vertex="1" parent="1"><mxGeometry x="1325" y="1802" width="215" height="71" as="geometry"/></mxCell></object><object label="app_state.json&lt;br&gt;(+ project_name.txt)&lt;br&gt;projects/{activity_id}/app_state.json" tooltip="&lt;b&gt;projects/{activity_id}/app_state.json&lt;/b&gt;&lt;br&gt;&lt;br&gt;Saved webapp session for this activity: all widget values, user edits, and the last prediction. Written to app_state_temp.json then app_state.json. Separate lifecycle from extraction: it persists and restores the user&#x27;s working session, not PDF-derived data." link="https://github.com/morganrivers/iati_webapp/blob/main/projects/webapp_39a1625529b1/app_state.json" id="appstate"><mxCell style="shape=cylinder;whiteSpace=wrap;html=1;fillColor=#e6ecf3;strokeColor=#8493a4;fontColor=#1b2733;fontSize=11;" vertex="1" parent="1"><mxGeometry x="641" y="1934" width="268" height="71" as="geometry"/></mxCell></object><object label="project_manager&lt;br&gt;+ state_manager&lt;br&gt;webapp/project_manager.py" tooltip="&lt;b&gt;webapp/project_manager.py&lt;/b&gt;&lt;br&gt;&lt;br&gt;Saves and reloads a working session. Serialises st.session_state to app_state.json (autosaved via save_project_state_temp) and restores it into the page widgets on load." link="https://github.com/morganrivers/iati_webapp/blob/main/webapp/project_manager.py" id="pmgr"><mxCell style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;fillColor=#dfe7ef;strokeColor=#6b7f96;fontColor=#1b2733;" vertex="1" parent="1"><mxGeometry x="516" y="1805" width="189" height="65" as="geometry"/></mxCell></object><object label="🤖 feature_grader&lt;br&gt;webapp/modules/feature_grader.py" tooltip="&lt;b&gt;webapp/modules/feature_grader.py&lt;/b&gt;&lt;br&gt;&lt;br&gt;LLM grades the extracted free-text features into the numeric scores the RF model expects." link="https://github.com/morganrivers/iati_webapp/blob/main/webapp/modules/feature_grader.py" id="grade"><mxCell style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;fillColor=#e6d6f2;strokeColor=#8a5fb0;fontColor=#3d2757;" vertex="1" parent="1"><mxGeometry x="1305" y="1565" width="255" height="50" as="geometry"/></mxCell></object><object label="🤖 targets_embedder&lt;br&gt;webapp/modules/targets_embedder.py" tooltip="&lt;b&gt;webapp/modules/targets_embedder.py&lt;/b&gt;&lt;br&gt;&lt;br&gt;Embeds targets/summary text and projects it through the saved UMAP models into embedding features." link="https://github.com/morganrivers/iati_webapp/blob/main/webapp/modules/targets_embedder.py" id="embed"><mxCell style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;fillColor=#e6d6f2;strokeColor=#8a5fb0;fontColor=#3d2757;" vertex="1" parent="1"><mxGeometry x="1004" y="1565" width="268" height="50" as="geometry"/></mxCell></object><object label="location_features&lt;br&gt;webapp/modules/location_features.py" tooltip="&lt;b&gt;webapp/modules/location_features.py&lt;/b&gt;&lt;br&gt;&lt;br&gt;Derives GDP / CPIA / governance and region indicators plus reporting-org dummies from the activity&#x27;s location and organisation." link="https://github.com/morganrivers/iati_webapp/blob/main/webapp/modules/location_features.py" id="loc"><mxCell style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;fillColor=#e6d6f2;strokeColor=#8a5fb0;fontColor=#3d2757;" vertex="1" parent="1"><mxGeometry x="716" y="1565" width="255" height="50" as="geometry"/></mxCell></object><object label="rf_predictor&lt;br&gt;webapp/modules/rf_predictor.py" tooltip="&lt;b&gt;webapp/modules/rf_predictor.py&lt;/b&gt;&lt;br&gt;&lt;br&gt;impute_and_run_statistical_model(): imputes the assembled feature vector, then combines a per-org-mode baseline with the RF + ExtraTrees delta ensemble (clipped to 0–5) plus a start-year drift correction to produce the overall success rating." link="https://github.com/morganrivers/iati_webapp/blob/main/webapp/modules/rf_predictor.py" id="rf"><mxCell style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;fillColor=#e6d6f2;strokeColor=#8a5fb0;fontColor=#3d2757;" vertex="1" parent="1"><mxGeometry x="584" y="1454" width="222" height="50" as="geometry"/></mxCell></object><object label="tag_predictor&lt;br&gt;webapp/tag_predictor.py" tooltip="&lt;b&gt;webapp/tag_predictor.py&lt;/b&gt;&lt;br&gt;&lt;br&gt;Per-outcome-tag classifiers predict probabilities for individual success dimensions." link="https://github.com/morganrivers/iati_webapp/blob/main/webapp/tag_predictor.py" id="tags"><mxCell style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;fillColor=#e6d6f2;strokeColor=#8a5fb0;fontColor=#3d2757;" vertex="1" parent="1"><mxGeometry x="950" y="1343" width="175" height="50" as="geometry"/></mxCell></object><object label="shap_explainer&lt;br&gt;webapp/modules/shap_explainer.py" tooltip="&lt;b&gt;webapp/modules/shap_explainer.py&lt;/b&gt;&lt;br&gt;&lt;br&gt;Decomposes the RF prediction into signed per-feature contributions via tree_contributions." link="https://github.com/morganrivers/iati_webapp/blob/main/webapp/modules/shap_explainer.py" id="shap"><mxCell style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;fillColor=#e6d6f2;strokeColor=#8a5fb0;fontColor=#3d2757;" vertex="1" parent="1"><mxGeometry x="518" y="1343" width="235" height="50" as="geometry"/></mxCell></object><object label="session_state&lt;br&gt;[&#x27;prediction&#x27;]&lt;br&gt;st.session_state[&#x27;prediction&#x27;]" tooltip="&lt;b&gt;st.session_state[&#x27;prediction&#x27;]&lt;/b&gt;&lt;br&gt;&lt;br&gt;Overall success rating on a 0–5 scale: per-org baseline + RF/ExtraTrees ensemble delta + start-year correction (base, ens_delta, prediction). Written by the forecast handler in page_activity_forecasting.py; held in Streamlit session_state." link="https://github.com/morganrivers/iati_webapp/blob/main/webapp/pages/page_activity_forecasting.py#L331" id="pred"><mxCell style="shape=cylinder;whiteSpace=wrap;html=1;fillColor=#e6ecf3;strokeColor=#8493a4;fontColor=#1b2733;fontSize=11;" vertex="1" parent="1"><mxGeometry x="663" y="1211" width="222" height="71" as="geometry"/></mxCell></object><object label="session_state&lt;br&gt;[&#x27;shap_result&#x27;]&lt;br&gt;st.session_state[&#x27;shap_result&#x27;]" tooltip="&lt;b&gt;st.session_state[&#x27;shap_result&#x27;]&lt;/b&gt;&lt;br&gt;&lt;br&gt;Per-feature SHAP contribution breakdown plus base_value, from shap_explainer.compute_shap_values. Held in session_state; rendered as the contribution waterfall." link="https://github.com/morganrivers/iati_webapp/blob/main/webapp/pages/page_activity_forecasting.py#L337" id="shapout"><mxCell style="shape=cylinder;whiteSpace=wrap;html=1;fillColor=#e6ecf3;strokeColor=#8493a4;fontColor=#1b2733;fontSize=11;" vertex="1" parent="1"><mxGeometry x="115" y="1211" width="228" height="71" as="geometry"/></mxCell></object><object label="session_state&lt;br&gt;[&#x27;tag_predictions&#x27;]&lt;br&gt;st.session_state[&#x27;tag_predictions&#x27;]" tooltip="&lt;b&gt;st.session_state[&#x27;tag_predictions&#x27;]&lt;/b&gt;&lt;br&gt;&lt;br&gt;Per-outcome-tag probabilities {tag: p}, from tag_predictor.predict_outcome_tags. Held in session_state; rendered as the per-dimension tag panel." link="https://github.com/morganrivers/iati_webapp/blob/main/webapp/pages/page_activity_forecasting.py#L344" id="tagout"><mxCell style="shape=cylinder;whiteSpace=wrap;html=1;fillColor=#e6ecf3;strokeColor=#8493a4;fontColor=#1b2733;fontSize=11;" vertex="1" parent="1"><mxGeometry x="375" y="1211" width="255" height="71" as="geometry"/></mxCell></object><object label="🤖 rag_bm25&lt;br&gt;(retrieval)&lt;br&gt;webapp/modules/rag_bm25.py" tooltip="&lt;b&gt;webapp/modules/rag_bm25.py&lt;/b&gt;&lt;br&gt;&lt;br&gt;Retrieves the most similar historical activities (BM25 by default, or Gemini-embedding cosine) to ground the narrative forecast." link="https://github.com/morganrivers/iati_webapp/blob/main/webapp/modules/rag_bm25.py" id="rag"><mxCell style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;fillColor=#f6d9c0;strokeColor=#c17a3a;fontColor=#5a3410;" vertex="1" parent="1"><mxGeometry x="1093" y="557" width="215" height="65" as="geometry"/></mxCell></object><object label="🤖 run_rag_forecast&lt;br&gt;webapp/run_rag_forecast.py" tooltip="&lt;b&gt;webapp/run_rag_forecast.py&lt;/b&gt;&lt;br&gt;&lt;br&gt;Synthesizes an LLM narrative forecast of likely outcomes, using the RF prediction as a reference point and the retrieved neighbours as evidence." link="https://github.com/morganrivers/iati_webapp/blob/main/webapp/run_rag_forecast.py" id="ragfc"><mxCell style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;fillColor=#f6d9c0;strokeColor=#c17a3a;fontColor=#5a3410;" vertex="1" parent="1"><mxGeometry x="764" y="446" width="215" height="50" as="geometry"/></mxCell></object><object label="session_state&lt;br&gt;[&#x27;rag_last_log&#x27;]&lt;br&gt;st.session_state[&#x27;rag_last_log&#x27;]" tooltip="&lt;b&gt;st.session_state[&#x27;rag_last_log&#x27;]&lt;/b&gt;&lt;br&gt;&lt;br&gt;Free-text outcome forecast with commentary, accumulated as log lines by run_rag_forecast and shown on the Narrative Forecast page." link="https://github.com/morganrivers/iati_webapp/blob/main/webapp/pages/page_rag_forecast.py#L229" id="narr"><mxCell style="shape=cylinder;whiteSpace=wrap;html=1;fillColor=#e6ecf3;strokeColor=#8493a4;fontColor=#1b2733;fontSize=11;" vertex="1" parent="1"><mxGeometry x="694" y="314" width="235" height="71" as="geometry"/></mxCell></object><object label="Activity&lt;br&gt;Forecasting&lt;br&gt;webapp/pages/page_activity_forecasting.py" tooltip="&lt;b&gt;webapp/pages/page_activity_forecasting.py&lt;/b&gt;&lt;br&gt;&lt;br&gt;Main page, now a thin orchestrator over the pages/activity_forecasting/ subpackage (project_selector, upload, inputs, sectors, grading, embeddings, analysis, tags): drives extraction + prediction and shows the rating, editable feature sliders, and SHAP annotations." link="https://github.com/morganrivers/iati_webapp/blob/main/webapp/pages/page_activity_forecasting.py" id="pforecast"><mxCell style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;fillColor=#cfe8e6;strokeColor=#4f9b95;fontColor=#163a37;" vertex="1" parent="1"><mxGeometry x="269" y="126" width="294" height="65" as="geometry"/></mxCell></object><object label="View Extracted&lt;br&gt;Data&lt;br&gt;webapp/pages/page_extracted_data.py" tooltip="&lt;b&gt;webapp/pages/page_extracted_data.py&lt;/b&gt;&lt;br&gt;&lt;br&gt;Displays the raw cached extraction outputs for the uploaded PDF." link="https://github.com/morganrivers/iati_webapp/blob/main/webapp/pages/page_extracted_data.py" id="pextracted"><mxCell style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;fillColor=#cfe8e6;strokeColor=#4f9b95;fontColor=#163a37;" vertex="1" parent="1"><mxGeometry x="1263" y="126" width="255" height="65" as="geometry"/></mxCell></object><object label="Narrative&lt;br&gt;Forecast [beta]&lt;br&gt;webapp/pages/page_rag_forecast.py" tooltip="&lt;b&gt;webapp/pages/page_rag_forecast.py&lt;/b&gt;&lt;br&gt;&lt;br&gt;Runs and displays the RAG narrative forecast." link="https://github.com/morganrivers/iati_webapp/blob/main/webapp/pages/page_rag_forecast.py" id="prag"><mxCell style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;fillColor=#cfe8e6;strokeColor=#4f9b95;fontColor=#163a37;" vertex="1" parent="1"><mxGeometry x="691" y="126" width="241" height="65" as="geometry"/></mxCell></object><object label="Model&lt;br&gt;Performance&lt;br&gt;webapp/pages/page_model_performance.py" tooltip="&lt;b&gt;webapp/pages/page_model_performance.py&lt;/b&gt;&lt;br&gt;&lt;br&gt;Shows model accuracy / explained-variance metrics against the validation set." link="https://github.com/morganrivers/iati_webapp/blob/main/webapp/pages/page_model_performance.py" id="pperf"><mxCell style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;fillColor=#cfe8e6;strokeColor=#4f9b95;fontColor=#163a37;" vertex="1" parent="1"><mxGeometry x="969" y="-0" width="274" height="65" as="geometry"/></mxCell></object><object label="Glossary /&lt;br&gt;About / Feedback&lt;br&gt;webapp/pages/" tooltip="&lt;b&gt;webapp/pages/&lt;/b&gt;&lt;br&gt;&lt;br&gt;Static informational pages: glossary of terms, project background, and a feedback form." link="https://github.com/morganrivers/iati_webapp/tree/main/webapp/pages" id="pmisc"><mxCell style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;fillColor=#cfe8e6;strokeColor=#4f9b95;fontColor=#163a37;" vertex="1" parent="1"><mxGeometry x="1632" y="126" width="129" height="65" as="geometry"/></mxCell></object></root></mxGraphModel></diagram></mxfile>