lor=#9aa6b3;fontSize=9;fontColor=#5b6675;strokeColor=#2e8b57;" edge="1" parent="1" source="pred" target="ragfc"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="1458" y="1144"/><mxPoint x="1232" y="1056"/><mxPoint x="1232" y="1056"/><mxPoint x="1232" y="1056"/><mxPoint x="1232" y="1056"/><mxPoint x="1232" y="692"/><mxPoint x="1232" y="692"/><mxPoint x="1161" y="542"/><mxPoint x="1161" y="542"/><mxPoint x="1161" y="542"/><mxPoint x="1142" y="514"/></Array></mxGeometry></mxCell><mxCell id="e42" value="neighbours" style="edgeStyle=none;curved=1;html=1;endArrow=block;endFill=1;strokeColor=#9aa6b3;fontSize=9;fontColor=#5b6675;strokeColor=#2e8b57;" edge="1" parent="1" source="rag" target="ragfc"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="1011" y="525"/><mxPoint x="1040" y="504"/></Array></mxGeometry></mxCell><mxCell id="e43" style="edgeStyle=none;curved=1;html=1;endArrow=block;endFill=1;strokeColor=#9aa6b3;fontSize=9;fontColor=#5b6675;strokeColor=#2e8b57;" edge="1" parent="1" source="ragfc" target="narr"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="1107" y="416"/><mxPoint x="1109" y="397"/></Array></mxGeometry></mxCell><mxCell id="e44" value="renders" style="edgeStyle=none;curved=1;html=1;endArrow=block;endFill=1;strokeColor=#9aa6b3;fontSize=9;fontColor=#5b6675;strokeColor=#2e8b57;" edge="1" parent="1" source="pred" target="pforecast"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="1634" y="1144"/><mxPoint x="1591" y="1056"/><mxPoint x="1591" y="1056"/><mxPoint x="1591" y="1056"/><mxPoint x="1591" y="1056"/><mxPoint x="1591" y="341"/><mxPoint x="1591" y="341"/><mxPoint x="1512" y="252"/></Array></mxGeometry></mxCell><mxCell id="e45" value="waterfall" style="edgeStyle=none;curved=1;html=1;endArrow=block;endFill=1;strokeColor=#9aa6b3;fontSize=9;fontColor=#5b6675;strokeColor=#2e8b57;" edge="1" parent="1" source="shapout" target="pforecast"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="1245" y="1144"/><mxPoint x="1364" y="1056"/><mxPoint x="1364" y="1056"/><mxPoint x="1364" y="1056"/><mxPoint x="1364" y="1056"/><mxPoint x="1364" y="341"/><mxPoint x="1364" y="341"/><mxPoint x="1396" y="254"/></Array></mxGeometry></mxCell><mxCell id="e46" value="tag panel" style="edgeStyle=none;curved=1;html=1;endArrow=block;endFill=1;strokeColor=#9aa6b3;fontSize=9;fontColor=#5b6675;strokeColor=#2e8b57;" edge="1" parent="1" source="tagout" target="pforecast"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="1417" y="1144"/><mxPoint x="1430" y="1056"/><mxPoint x="1430" y="1056"/><mxPoint x="1430" y="1056"/><mxPoint x="1430" y="1056"/><mxPoint x="1430" y="341"/><mxPoint x="1430" y="341"/><mxPoint x="1430" y="255"/></Array></mxGeometry></mxCell><mxCell id="e47" style="edgeStyle=none;curved=1;html=1;endArrow=block;endFill=1;strokeColor=#9aa6b3;fontSize=9;fontColor=#5b6675;strokeColor=#2e8b57;" edge="1" parent="1" source="cache" target="pextracted"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="412" y="1774"/><mxPoint x="325" y="1740"/><mxPoint x="325" y="1740"/><mxPoint x="325" y="1740"/><mxPoint x="99" y="1614"/><mxPoint x="99" y="1614"/><mxPoint x="99" y="1614"/><mxPoint x="0" y="1472"/><mxPoint x="0" y="1472"/><mxPoint x="0" y="1472"/><mxPoint x="0" y="1472"/><mxPoint x="0" y="341"/><mxPoint x="0" y="341"/><mxPoint x="156" y="249"/></Array></mxGeometry></mxCell><mxCell id="e48" style="edgeStyle=none;curved=1;html=1;endArrow=block;endFill=1;strokeColor=#9aa6b3;fontSize=9;fontColor=#5b6675;strokeColor=#2e8b57;" edge="1" parent="1" source="narr" target="prag"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="1114" y="284"/><mxPoint x="1115" y="236"/></Array></mxGeometry></mxCell><mxCell id="e49" value="metrics" style="edgeStyle=none;curved=1;html=1;endArrow=block;endFill=1;strokeColor=#9aa6b3;fontSize=9;fontColor=#5b6675;strokeColor=#8493a4;dashed=1;" edge="1" parent="1" source="SX_train_pperf" target="pperf"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="888" y="124"/><mxPoint x="876" y="97"/></Array></mxGeometry></mxCell><mxCell id="e50" style="edgeStyle=none;curved=1;html=1;endArrow=block;endFill=1;strokeColor=#9aa6b3;fontSize=9;fontColor=#5b6675;strokeColor=#8493a4;dashed=1;" edge="1" parent="1" source="app" target="pmisc"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="1168" y="2983"/><mxPoint x="1901" y="2824"/><mxPoint x="1901" y="2824"/><mxPoint x="1901" y="2824"/><mxPoint x="1901" y="2824"/><mxPoint x="1901" y="341"/><mxPoint x="1901" y="341"/><mxPoint x="1849" y="254"/></Array></mxGeometry></mxCell><object label="PDF upload&lt;br&gt;/ manual entry&lt;br&gt;webapp/pages/activity_forecasting/upload.py" tooltip="&lt;b&gt;webapp/pages/activity_forecasting/upload.py&lt;/b&gt;&lt;br&gt;&lt;br&gt;User uploads a project-document PDF (or types activity details) on the Activity Forecasting page. Rendered by the upload submodule of the pages/activity_forecasting/ package." id="upload"><mxCell style="rounded=1;whiteSpace=wrap;html=1;arcSize=45;fillColor=#2f7dc4;strokeColor=#1c4f80;fontColor=#ffffff;fontSize=11;" vertex="1" parent="1"><mxGeometry x="725" y="2885" width="307" height="65" as="geometry"/></mxCell></object><object label="app.py&lt;br&gt;(Streamlit host)&lt;br&gt;webapp/app.py" tooltip="&lt;b&gt;webapp/app.py&lt;/b&gt;&lt;br&gt;&lt;br&gt;Streamlit entrypoint. Renders the sidebar nav over 7 pages and loads the model + training data once at startup via model_loader." id="app"><mxCell style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;fillColor=#dfe7ef;strokeColor=#6b7f96;fontColor=#1b2733;" vertex="1" parent="1"><mxGeometry x="814" y="3014" width="129" height="65" as="geometry"/></mxCell></object><object label="model_loader&lt;br&gt;webapp/model_loader.py" tooltip="&lt;b&gt;webapp/model_loader.py&lt;/b&gt;&lt;br&gt;&lt;br&gt;Loads the trained Random Forest + ExtraTrees ensemble, per-org baseline, start-year correction, feature medians, metadata, and training data from data/rating_model_outputs at startup." id="loader"><mxCell style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;fillColor=#dfe7ef;strokeColor=#6b7f96;fontColor=#1b2733;" vertex="1" parent="1"><mxGeometry x="459" y="2893" width="169" height="50" as="geometry"/></mxCell></object><object label="RF + ExtraTrees&lt;br&gt;model .pkl&lt;br&gt;data/rating_model_outputs/" tooltip="&lt;b&gt;data/rating_model_outputs/&lt;/b&gt;&lt;br&gt;&lt;br&gt;Trained Random Forest + ExtraTrees delta regressors (model.pkl, extra_model.pkl), per-org baseline, start-year correction, and feature medians produced offline by the forecasting model-training pipeline." id="rfpkl"><mxCell style="rounded=1;whiteSpace=wrap;html=1;arcSize=45;fillColor=#2f7dc4;strokeColor=#1c4f80;fontColor=#ffffff;fontSize=11;" vertex="1" parent="1"><mxGeometry x="502" y="3014" width="195" height="65" as="geometry"/></mxCell></object><object label="training data&lt;br&gt;(~1,300 activities)&lt;br&gt;data/rating_model_outputs/" tooltip="&lt;b&gt;data/rating_model_outputs/&lt;/b&gt;&lt;br&gt;&lt;br&gt;Historical IATI activity features + ratings. Used as the model&#x27;s reference distribution, for performance metrics, and as the RAG retrieval corpus. Consumed in several bands, so it is exported via the ✳ proxy convention (a small &#x27;training data ✳&#x27; chip beside each importer) rather than long lines." id="train"><mxCell style="shape=cylinder;whiteSpace=wrap;html=1;fillColor=#e6ecf3;strokeColor=#8493a4;fontColor=#1b2733;fontSize=11;" vertex="1" parent="1"><mxGeometry x="1887" y="3011" width="195" height="71" as="geometry"/></mxCell></object><object label="✳" tooltip="training data is exported via the ✳ proxy convention: each importer is drawn with a small &#x27;training data ✳&#x27; chip beside it rather than long lines from this file." id="STAR_train"><mxCell style="shape=note;whiteSpace=wrap;html=1;size=14;fillColor=#fdf3cf;strokeColor=#c9a227;fontColor=#5b4a00;fontSize=12;dashed=1;" vertex="1" parent="1"><mxGeometry x="1965" y="2902" width="70" height="32" as="geometry"/></mxCell></object><object label="UMAP models&lt;br&gt;.pkl&lt;br&gt;data/trained_umap_models_trainval.pkl" tooltip="&lt;b&gt;data/trained_umap_models_trainval.pkl&lt;/b&gt;&lt;br&gt;&lt;br&gt;Saved UMAP reducers that compress target/summary embeddings into a small set of embedding features." id="umap"><mxCell style="rounded=1;whiteSpace=wrap;html=1;arcSize=45;fillColor=#2f7dc4;strokeColor=#1c4f80;fontColor=#ffffff;fontSize=11;" vertex="1" parent="1"><mxGeometry x="469" y="1675" width="268" height="65" as="geometry"/></mxCell></object><object label="outcome-tag&lt;br&gt;models .pkl&lt;br&gt;data/outcome_tags/tag_models.pkl" tooltip="&lt;b&gt;data/outcome_tags/tag_models.pkl&lt;/b&gt;&lt;br&gt;&lt;br&gt;Per-outcome-tag classifiers produced offline by the forecasting model-training pipeline. Loaded at runtime by tag_model_loader.py and consumed by tag_predictor to score individual success dimensions." id="tagpkl"><mxCell style="rounded=1;whiteSpace=wrap;html=1;arcSize=45;fillColor=#2f7dc4;strokeColor=#1c4f80;fontColor=#ffffff;fontSize=11;" vertex="1" parent="1"><mxGeometry x="922" y="1438" width="235" height="65" as="geometry"/></mxCell></object><object label="build_webapp_db&lt;br&gt;(offline prep)&lt;br&gt;webapp/scripts/build_webapp_db.py" tooltip="&lt;b&gt;webapp/scripts/build_webapp_db.py&lt;/b&gt;&lt;br&gt;&lt;br&gt;Offline one-off. Packs the training-data CSV plus summaries/risks/retrospective-forecast JSONL into data/webapp.db (tables activity_info and mock_forecasts)." id="builddb"><mxCell style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;fillColor=#dfe7ef;strokeColor=#6b7f96;fontColor=#1b2733;" vertex="1" parent="1"><mxGeometry x="810" y="911" width="241" height="65" as="geometry"/></mxCell></object><object label="build_embeddings_db&lt;br&gt;(offline prep)&lt;br&gt;webapp/build_embeddings_db.py" tooltip="&lt;b&gt;webapp/build_embeddings_db.py&lt;/b&gt;&lt;br&gt;&lt;br&gt;Offline one-off. Adds an embeddings table to data/webapp.db from activity_text_embeddings_gemini.jsonl, stored as float32 BLOBs so the DB is small enough to commit." id="buildemb"><mxCell style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;fillColor=#dfe7ef;strokeColor=#6b7f96;fontColor=#1b2733;" vertex="1" parent="1"><mxGeometry x="563" y="911" width="215" height="65" as="geometry"/></mxCell></object><object label="webapp.db&lt;br&gt;(SQLite)&lt;br&gt;data/webapp.db" tooltip="&lt;b&gt;data/webapp.db&lt;/b&gt;&lt;br&gt;&lt;br&gt;SQLite corpus database: activity_info, mock_forecasts, and embeddings tables. Built offline by the build_* scripts; read at runtime by sqlite_loaders." id="webappdb"><mxCell style="shape=cylinder;whiteSpace=wrap;html=1;fillColor=#e6ecf3;strokeColor=#8493a4;fontColor=#1b2733;fontSize=11;" vertex="1" parent="1"><mxGeometry x="800" y="779" width="116" height="71" as="geometry"/></mxCell></object><object label="sqlite_loaders&lt;br&gt;webapp/modules/sqlite_loaders.py" tooltip="&lt;b&gt;webapp/modules/sqlite_loaders.py&lt;/b&gt;&lt;br&gt;&lt;br&gt;Runtime reader of webapp.db. Supplies the BM25 retrieval corpus, activity-info lookups, and lazy mock forecasts that ground the narrative forecast." id="sqlite"><mxCell style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;fillColor=#f6d9c0;strokeColor=#c17a3a;fontColor=#5a3410;" vertex="1" parent="1"><mxGeometry x="741" y="668" width="235" height="50" as="geometry"/></mxCell></object><object label="training data ✳" tooltip="Proxy for training data (see the ✳ node); loaded here by model_loader at startup." id="SX_train_loader"><mxCell style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eef2f7;strokeColor=#8493a4;fontColor=#5b6675;fontSize=9;dashed=1;" vertex="1" parent="1"><mxGeometry x="348" y="3029" width="123" height="35" as="geometry"/></mxCell></object><object label="training data ✳" tooltip="Proxy for training data (see the ✳ node); the historical-activity rows that build_webapp_db packs into webapp.db to become the RAG retrieval corpus." id="SX_train_rag"><mxCell style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eef2f7;strokeColor=#8493a4;fontColor=#5b6675;fontSize=9;dashed=1;" vertex="1" parent="1"><mxGeometry x="869" y="1037" width="123" height="35" as="geometry"/></mxCell></object><object label="training data ✳" tooltip="Proxy for training data (see the ✳ node); source of the validation metrics shown on the Model Performance page." id="SX_train_pperf"><mxCell style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eef2f7;strokeColor=#8493a4;fontColor=#5b6675;fontSize=9;dashed=1;" vertex="1" parent="1"><mxGeometry x="842" y="141" width="123" height="35" as="geometry"/></mxCell></object><object label="webapp_pipeline&lt;br&gt;(orchestrator)&lt;br&gt;webapp/modules/webapp_pipeline.py" tooltip="&lt;b&gt;webapp/modules/webapp_pipeline.py&lt;/b&gt;&lt;br&gt;&lt;br&gt;process_uploaded_pdf(): runs the 5-phase extraction on one PDF. Caches every output under extracted_pdf_data/{activity_id}/ and reuses it on re-upload (activity_id = PDF content hash)." id="pipeline"><mxCell style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;fillColor=#cfe6cf;strokeColor=#5a9367;fontColor=#1e3a24;" vertex="1" parent="1"><mxGeometry x="730" y="2697" width="241" height="65" as="geometry"/></mxCell></object><object label="🤖 metadata_extractor&lt;br&gt;webapp/modules/metadata_extractor.py" tooltip="&lt;b&gt;webapp/modules/metadata_extractor.py&lt;/b&gt;&lt;br&gt;&lt;br&gt;Phase 1/5: LLM extracts title, reporting/participating orgs, country locations, and dates." id="meta"><mxCell style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;fillColor=#cfe6cf;strokeColor=#5a9367;fontColor=#1e3a24;" vertex="1" parent="1"><mxGeometry x="638" y="2586" width="281" height="50" as="geometry"/></mxCell></object><object label="🤖 page_categorizer&lt;br&gt;webapp/modules/page_categorizer.py" tooltip="&lt;b&gt;webapp/modules/page_categorizer.py&lt;/b&gt;&lt;br&gt;&lt;br&gt;Phase 2/5: LLM labels each PDF page (baseline vs outcome, plus subcategories)." id="pagecat"><mxCell style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;fillColor=#cfe6cf;strokeColor=#5a9367;fontColor=#1e3a24;" vertex="1" parent="1"><mxGeometry x="519" y="2475" width="268" height="50" as="geometry"/></mxCell></object><object label="🤖 summary_generator&lt;br&gt;webapp/modules/summary_generator.py" tooltip="&lt;b&gt;webapp/modules/summary_generator.py&lt;/b&gt;&lt;br&gt;&lt;br&gt;Phase 3/5: LLM writes an activity-description summary from the categorized pages." id="summary"><mxCell style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;fillColor=#cfe6cf;strokeColor=#5a9367;fontColor=#1e3a24;" vertex="1" parent="1"><mxGeometry x="330" y="2364" width="275" height="50" as="geometry"/></mxCell></object><object label="🤖 finance_extractor&lt;br&gt;(+ sector_extractor)&lt;br&gt;webapp/modules/finance_extractor.py" tooltip="&lt;b&gt;webapp/modules/finance_extractor.py&lt;/b&gt;&lt;br&gt;&lt;br&gt;Phase 4/5: LLM extracts a finance breakdown (allocations, total amount); a companion sector_extractor.py allocates expenditure across the model&#x27;s sector clusters in the same phase." id="finance"><mxCell style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;fillColor=#cfe6cf;strokeColor=#5a9367;fontColor=#1e3a24;" vertex="1" parent="1"><mxGeometry x="247" y="2238" width="275" height="65" as="geometry"/></mxCell></object><object label="🤖 feature_extractor&lt;br&gt;webapp/modules/feature_extractor.py" tooltip="&lt;b&gt;webapp/modules/feature_extractor.py&lt;/b&gt;&lt;br&gt;&lt;br&gt;Phase 5/5: LLM extracts baseline features: implementer performance, targets, risks, context, finance-qualitative, and complexity/integratedness." id="features"><mxCell style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;fillColor=#cfe6cf;strokeColor=#5a9367;fontColor=#1e3a24;" vertex="1" parent="1"><mxGeometry x="182" y="2127" width="275" height="50" as="geometry"/></mxCell></object><object label="extraction outputs&lt;br&gt;(uploaded.pdf + phase .jsonl)&lt;br&gt;webapp/extracted_pdf_data/{activity_id}/" tooltip="&lt;b&gt;webapp/extracted_pdf_data/{activity_id}/&lt;/b&gt;&lt;br&gt;&lt;br&gt;Per-PDF extraction artifacts: uploaded.pdf plus metadata.json and page_categories / summary / finance_breakdown / implementer_performance / targets / risks / context / finance_qualitative / misc .jsonl. Written by the extraction phases; the PREDICT band later writes feature_grades.jsonl and targets_embedding_features.jsonl back here. Reused on re-upload of the same PDF." id="cache"><mxCell style="shape=cylinder;whiteSpace=wrap;html=1;fillColor=#e6ecf3;strokeColor=#8493a4;fontColor=#1b2733;fontSize=11;" vertex="1" parent="1"><mxGeometry x="428" y="1801" width="288" height="71" as="geometry"/></mxCell></object><object label="app_state.json&lt;br&gt;(+ project_name.txt)&lt;br&gt;webapp/extracted_pdf_data/{activity_id}/app_state.json" tooltip="&lt;b&gt;webapp/extracted_pdf_data/{activity_id}/app_state.json&lt;/b&gt;&lt;br&gt;&lt;br&gt;Saved webapp session for this activity: all widget values, user edits, and the last prediction. Written to app_state_temp.json then app_state.json. Separate lifecycle from extraction: it persists and restores the user&#x27;s working session, not PDF-derived data." id="appstate"><mxCell style="shape=cylinder;whiteSpace=wrap;html=1;fillColor=#e6ecf3;strokeColor=#8493a4;fontColor=#1b2733;fontSize=11;" vertex="1" parent="1"><mxGeometry x="839" y="1933" width="380" height="71" as="geometry"/></mxCell></object><object label="project_manager&lt;br&gt;+ state_manager&lt;br&gt;webapp/project_manager.py" tooltip="&lt;b&gt;webapp/project_manager.py&lt;/b&gt;&lt;br&gt;&lt;br&gt;Saves and reloads a working session. Serialises st.session_state to app_state.json (autosaved via save_project_state_temp) and restores it into the page widgets on load." id="pmgr"><mxCell style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;fillColor=#dfe7ef;strokeColor=#6b7f96;fontColor=#1b2733;" vertex="1" parent="1"><mxGeometry x="1125" y="1804" width="189" height="65" as="geometry"/></mxCell></object><object label="🤖 feature_grader&lt;br&gt;webapp/modules/feature_grader.py" tooltip="&lt;b&gt;webapp/modules/feature_grader.py&lt;/b&gt;&lt;br&gt;&lt;br&gt;LLM grades the extracted free-text features into the numeric scores the RF model expects." id="grade"><mxCell style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;fillColor=#e6d6f2;strokeColor=#8a5fb0;fontColor=#3d2757;" vertex="1" parent="1"><mxGeometry x="116" y="1564" width="255" height="50" as="geometry"/></mxCell></object><object label="🤖 targets_embedder&lt;br&gt;webapp/modules/targets_embedder.py" tooltip="&lt;b&gt;webapp/modules/targets_embedder.py&lt;/b&gt;&lt;br&gt;&lt;br&gt;Embeds targets/summary text and projects it through the saved UMAP models into embedding features." id="embed"><mxCell style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;fillColor=#e6d6f2;strokeColor=#8a5fb0;fontColor=#3d2757;" vertex="1" parent="1"><mxGeometry x="469" y="1564" width="268" height="50" as="geometry"/></mxCell></object><object label="location_features&lt;br&gt;webapp/modules/location_features.py" tooltip="&lt;b&gt;webapp/modules/location_features.py&lt;/b&gt;&lt;br&gt;&lt;br&gt;Derives GDP / CPIA / governance and region indicators plus reporting-org dummies from the activity&#x27;s location and organisation." id="loc"><mxCell style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;fillColor=#e6d6f2;strokeColor=#8a5fb0;fontColor=#3d2757;" vertex="1" parent="1"><mxGeometry x="902" y="1564" width="255" height="50" as="geometry"/></mxCell></object><object label="rf_predictor&lt;br&gt;webapp/modules/rf_predictor.py" tooltip="&lt;b&gt;webapp/modules/rf_predictor.py&lt;/b&gt;&lt;br&gt;&lt;br&gt;impute_and_run_statistical_model(): imputes the assembled feature vector, then combines a per-org-mode baseline with the RF + ExtraTrees delta ensemble (clipped to 0–5) plus a start-year drift correction to produce the overall success rating." id="rf"><mxCell style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;fillColor=#e6d6f2;strokeColor=#8a5fb0;fontColor=#3d2757;" vertex="1" parent="1"><mxGeometry x="667" y="1446" width="222" height="50" as="geometry"/></mxCell></object><object label="tag_predictor&lt;br&gt;webapp/tag_predictor.py" tooltip="&lt;b&gt;webapp/tag_predictor.py&lt;/b&gt;&lt;br&gt;&lt;br&gt;Per-outcome-tag classifiers predict probabilities for individual success dimensions." id="tags"><mxCell style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;fillColor=#e6d6f2;strokeColor=#8a5fb0;fontColor=#3d2757;" vertex="1" parent="1"><mxGeometry x="952" y="1327" width="175" height="50" as="geometry"/></mxCell></object><object label="shap_explainer&lt;br&gt;webapp/modules/shap_explainer.py" tooltip="&lt;b&gt;webapp/modules/shap_explainer.py&lt;/b&gt;&lt;br&gt;&lt;br&gt;Decomposes the RF prediction into signed per-feature contributions via tree_contributions." id="shap"><mxCell style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;fillColor=#e6d6f2;strokeColor=#8a5fb0;fontColor=#3d2757;" vertex="1" parent="1"><mxGeometry x="562" y="1327" width="235" height="50" as="geometry"/></mxCell></object><object label="session_state&lt;br&gt;[&#x27;prediction&#x27;]&lt;br&gt;st.session_state[&#x27;prediction&#x27;]" tooltip="&lt;b&gt;st.session_state[&#x27;prediction&#x27;]&lt;/b&gt;&lt;br&gt;&lt;br&gt;Overall success rating on a 0–5 scale: per-org baseline + RF/ExtraTrees ensemble delta + start-year correction (base, ens_delta, prediction). Written by the forecast handler in page_activity_forecasting.py; held in Streamlit session_state." id="pred"><mxCell style="shape=cylinder;whiteSpace=wrap;html=1;fillColor=#e6ecf3;strokeColor=#8493a4;fontColor=#1b2733;fontSize=11;" vertex="1" parent="1"><mxGeometry x="1564" y="1195" width="222" height="71" as="geometry"/></mxCell></object><object label="session_state&lt;br&gt;[&#x27;shap_result&#x27;]&lt;br&gt;st.session_state[&#x27;shap_result&#x27;]" tooltip="&lt;b&gt;st.session_state[&#x27;shap_result&#x27;]&lt;/b&gt;&lt;br&gt;&lt;br&gt;Per-feature SHAP contribution breakdown plus base_value, from shap_explainer.compute_shap_values. Held in session_state; rendered as the contribution waterfall." id="shapout"><mxCell style="shape=cylinder;whiteSpace=wrap;html=1;fillColor=#e6ecf3;strokeColor=#8493a4;fontColor=#1b2733;fontSize=11;" vertex="1" parent="1"><mxGeometry x="1016" y="1195" width="228" height="71" as="geometry"/></mxCell></object><object label="session_state&lt;br&gt;[&#x27;tag_predictions&#x27;]&lt;br&gt;st.session_state[&#x27;tag_predictions&#x27;]" tooltip="&lt;b&gt;st.session_state[&#x27;tag_predictions&#x27;]&lt;/b&gt;&lt;br&gt;&lt;br&gt;Per-outcome-tag probabilities {tag: p}, from tag_predictor.predict_outcome_tags. Held in session_state; rendered as the per-dimension tag panel." id="tagout"><mxCell style="shape=cylinder;whiteSpace=wrap;html=1;fillColor=#e6ecf3;strokeColor=#8493a4;fontColor=#1b2733;fontSize=11;" vertex="1" parent="1"><mxGeometry x="1276" y="1195" width="255" height="71" as="geometry"/></mxCell></object><object label="🤖 rag_bm25&lt;br&gt;(retrieval)&lt;br&gt;webapp/modules/rag_bm25.py" tooltip="&lt;b&gt;webapp/modules/rag_bm25.py&lt;/b&gt;&lt;br&gt;&lt;br&gt;Retrieves the most similar historical activities (BM25 by default, or Gemini-embedding cosine) to ground the narrative forecast." id="rag"><mxCell style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;fillColor=#f6d9c0;strokeColor=#c17a3a;fontColor=#5a3410;" vertex="1" parent="1"><mxGeometry x="835" y="542" width="215" height="65" as="geometry"/></mxCell></object><object label="🤖 run_rag_forecast&lt;br&gt;webapp/run_rag_forecast.py" tooltip="&lt;b&gt;webapp/run_rag_forecast.py&lt;/b&gt;&lt;br&gt;&lt;br&gt;Synthesizes an LLM narrative forecast of likely outcomes, using the RF prediction as a reference point and the retrieved neighbours as evidence." id="ragfc"><mxCell style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;fillColor=#f6d9c0;strokeColor=#c17a3a;fontColor=#5a3410;" vertex="1" parent="1"><mxGeometry x="997" y="431" width="215" height="50" as="geometry"/></mxCell></object><object label="narrative&lt;br&gt;forecast" tooltip="Free-text outcome forecast with commentary, shown on the Narrative Forecast page." id="narr"><mxCell style="shape=cylinder;whiteSpace=wrap;html=1;fillColor=#e6ecf3;strokeColor=#8493a4;fontColor=#1b2733;fontSize=11;" vertex="1" parent="1"><mxGeometry x="1067" y="314" width="90" height="56" as="geometry"/></mxCell></object><object label="Activity&lt;br&gt;Forecasting&lt;br&gt;webapp/pages/page_activity_forecasting.py" tooltip="&lt;b&gt;webapp/pages/page_activity_forecasting.py&lt;/b&gt;&lt;br&gt;&lt;br&gt;Main page, now a thin orchestrator over the pages/activity_forecasting/ subpackage (project_selector, upload, inputs, sectors, grading, embeddings, analysis, tags): drives extraction + prediction and shows the rating, editable feature sliders, and SHAP annotations." id="pforecast"><mxCell style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;fillColor=#cfe8e6;strokeColor=#4f9b95;fontColor=#163a37;" vertex="1" parent="1"><mxGeometry x="1283" y="126" width="294" height="65" as="geometry"/></mxCell></object><object label="View Extracted&lt;br&gt;Data&lt;br&gt;webapp/pages/page_extracted_data.py" tooltip="&lt;b&gt;webapp/pages/page_extracted_data.py&lt;/b&gt;&lt;br&gt;&lt;br&gt;Displays the raw cached extraction outputs for the uploaded PDF." id="pextracted"><mxCell style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;fillColor=#cfe8e6;strokeColor=#4f9b95;fontColor=#163a37;" vertex="1" parent="1"><mxGeometry x="181" y="126" width="255" height="65" as="geometry"/></mxCell></object><object label="Narrative&lt;br&gt;Forecast [beta]&lt;br&gt;webapp/pages/page_rag_forecast.py" tooltip="&lt;b&gt;webapp/pages/page_rag_forecast.py&lt;/b&gt;&lt;br&gt;&lt;br&gt;Runs and displays the RAG narrative forecast." id="prag"><mxCell style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;fillColor=#cfe8e6;strokeColor=#4f9b95;fontColor=#163a37;" vertex="1" parent="1"><mxGeometry x="997" y="126" width="241" height="65" as="geometry"/></mxCell></object><object label="Model&lt;br&gt;Performance&lt;br&gt;webapp/pages/page_model_performance.py" tooltip="&lt;b&gt;webapp/pages/page_model_performance.py&lt;/b&gt;&lt;br&gt;&lt;br&gt;Shows model accuracy / explained-variance metrics against the validation set." id="pperf"><mxCell style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;fillColor=#cfe8e6;strokeColor=#4f9b95;fontColor=#163a37;" vertex="1" parent="1"><mxGeometry x="710" y="0" width="274" height="65" as="geometry"/></mxCell></object><object label="Glossary /&lt;br&gt;About / Feedback&lt;br&gt;webapp/pages/" tooltip="&lt;b&gt;webapp/pages/&lt;/b&gt;&lt;br&gt;&lt;br&gt;Static informational pages: glossary of terms, project background, and a feedback form." id="pmisc"><mxCell style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;fillColor=#cfe8e6;strokeColor=#4f9b95;fontColor=#163a37;" vertex="1" parent="1"><mxGeometry x="1729" y="126" width="129" height="65" as="geometry"/></mxCell></object></root></mxGraphModel></diagram></mxfile>